<Window x:Class="DelphiVisualizer.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="420" Height="210" Topmost="True"
        ResizeMode="NoResize" ShowInTaskbar="False" Opacity="0">
    <Border Background="#0D1117" CornerRadius="10"
            BorderBrush="#2A3040" BorderThickness="1">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32">
            <TextBlock Text="⬡" FontSize="44" Foreground="#4FC3F7"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Delphi Dependency Visualizer"
                       FontSize="18" FontWeight="SemiBold" Foreground="#E8EAF0"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="v1.0  ·  Michael Bröker"
                       FontSize="11" Foreground="#6B7280"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock x:Name="TbLoading" Text="Wird geladen …"
                       FontSize="11" Foreground="#4FC3F7"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
